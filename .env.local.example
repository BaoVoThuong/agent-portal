# NextAuth
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GOOGLE_ALLOWED_DOMAIN=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (browser) — enables realtime notification toasts. Without these the
# notification bell falls back to polling. URL is the same as SUPABASE_URL.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Sheet sync (Apps Script Web App)
APPS_SCRIPT_URL=
APPS_SCRIPT_SECRET=

# Anthropic (AI dashboard chat)
ANTHROPIC_API_KEY=

# Google Maps Platform
GOOGLE_MAPS_API_KEY=

# Provider Finder Maps proxy (preferred when Google Maps Platform key is blocked)
APPS_SCRIPT_MAPS_WEBAPP_URL=
APPS_SCRIPT_MAPS_SECRET=
